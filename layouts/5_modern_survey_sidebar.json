{
  "schemaVersion": "2.0",
  "layoutMode": "Vertical_Navigation",
  "header": {
    "visible": true,
    "title": "Corporate Health Risk Assessment",
    "subtitle": "Complete all sections to receive your personalized fitness score report.",
    "showLogo": false,
    "logoUrl": "",
    "alignment": "left",
    "backgroundColor": "#ffffff",
    "titleColor": "#0f172a",
    "subtitleColor": "#475569"
  },
  "formSettings": {
    "submitLabel": "Submit Assessment",
    "afterSubmitMode": "Screen",
    "thankYouMessage": "<p><strong>Report Generated!</strong> Your results have been compiled and sent to your email.</p>",
    "formWidth": 100,
    "theme": {
      "name": "classic",
      "layout": "classic",
      "accent": "#0d9488",
      "surface": "#ffffff",
      "pageBg": "#f0fdfa",
      "radius": "rounded",
      "cardShadow": "soft",
      "sectionDefault": "card",
      "glass": false,
      "customCss": ""
    }
  },
  "pages": [
    {
      "id": "pg-general",
      "name": "General Health",
      "showInProgress": true,
      "sections": [
        {
          "id": "sec-health",
          "name": "Vital Health Stats",
          "showHeader": true,
          "gridColumns": 2,
          "padding": "medium",
          "contextType": "Parent",
          "elements": [
            {
              "id": "el-height",
              "type": "Field",
              "name": "Height (inches)",
              "fieldApiName": "Height__c",
              "fieldType": "Double",
              "uiBehavior": "None"
            },
            {
              "id": "el-weight",
              "type": "Field",
              "name": "Weight (lbs)",
              "fieldApiName": "Weight__c",
              "fieldType": "Double",
              "uiBehavior": "None"
            }
          ]
        }
      ]
    },
    {
      "id": "pg-lifestyle",
      "name": "Lifestyle Habits",
      "showInProgress": true,
      "sections": [
        {
          "id": "sec-lifestyle",
          "name": "Daily Routines",
          "showHeader": true,
          "gridColumns": 1,
          "padding": "medium",
          "contextType": "Parent",
          "elements": [
            {
              "id": "el-active",
              "type": "Field",
              "name": "How active are you?",
              "fieldApiName": "ActivityLevel__c",
              "fieldType": "Picklist",
              "uiBehavior": "None"
            }
          ]
        }
      ]
    },
    {
      "id": "pg-diet",
      "name": "Dietary Habits",
      "showInProgress": true,
      "sections": [
        {
          "id": "sec-diet",
          "name": "Nutrition Profile",
          "showHeader": true,
          "gridColumns": 1,
          "padding": "medium",
          "contextType": "Parent",
          "elements": [
            {
              "id": "el-water",
              "type": "Field",
              "name": "Daily water intake (cups)",
              "fieldApiName": "WaterIntake__c",
              "fieldType": "Integer",
              "uiBehavior": "None"
            }
          ]
        }
      ]
    }
  ]
}
