<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Related_Child_Requires_Relationship</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Context_Type__c, &quot;Related_Child&quot;),
  ISBLANK(Relationship_Name__c)
)</errorConditionFormula>
    <errorDisplayField>Relationship_Name__c</errorDisplayField>
    <errorMessage>Relationship Name is required for Related Child sections</errorMessage>
</ValidationRule>
