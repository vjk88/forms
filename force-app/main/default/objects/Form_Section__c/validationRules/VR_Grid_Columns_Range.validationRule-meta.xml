<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Grid_Columns_Range</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Grid_Columns__c)),
  OR(Grid_Columns__c &lt; 1, Grid_Columns__c &gt; 4)
)</errorConditionFormula>
    <errorDisplayField>Grid_Columns__c</errorDisplayField>
    <errorMessage>Grid Columns must be between 1 and 4</errorMessage>
</ValidationRule>
