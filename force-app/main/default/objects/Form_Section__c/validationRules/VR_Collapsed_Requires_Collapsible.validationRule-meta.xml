<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Collapsed_Requires_Collapsible</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  Collapsed_By_Default__c = TRUE,
  Collapsible__c = FALSE
)</errorConditionFormula>
    <errorDisplayField>Collapsed_By_Default__c</errorDisplayField>
    <errorMessage
  >Section must be Collapsible to be Collapsed by Default</errorMessage>
</ValidationRule>
