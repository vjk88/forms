<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Parent_Cannot_Have_Relationship</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Context_Type__c, &quot;Parent&quot;),
  NOT(ISBLANK(Relationship_Name__c))
)</errorConditionFormula>
    <errorDisplayField>Relationship_Name__c</errorDisplayField>
    <errorMessage>Parent sections cannot have a Relationship Name</errorMessage>
</ValidationRule>
