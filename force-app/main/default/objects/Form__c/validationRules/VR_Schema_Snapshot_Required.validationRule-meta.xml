<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Schema_Snapshot_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Status__c, &quot;Published&quot;),
  ISBLANK(Schema_Snapshot__c)
)</errorConditionFormula>
    <errorDisplayField>Schema_Snapshot__c</errorDisplayField>
    <errorMessage>Schema Snapshot is required for published forms</errorMessage>
</ValidationRule>
