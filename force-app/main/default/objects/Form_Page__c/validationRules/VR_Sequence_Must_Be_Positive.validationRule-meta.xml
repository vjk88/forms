<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Sequence_Must_Be_Positive</fullName>
    <active>true</active>
    <errorConditionFormula>Sequence__c &lt; 1</errorConditionFormula>
    <errorDisplayField>Sequence__c</errorDisplayField>
    <errorMessage>Sequence must be a positive integer</errorMessage>
</ValidationRule>
