<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Min_Max_Value_Range</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Min_Value__c)),
  NOT(ISBLANK(Max_Value__c)),
  Min_Value__c &gt; Max_Value__c
)</errorConditionFormula>
    <errorDisplayField>Min_Value__c</errorDisplayField>
    <errorMessage>Min Value cannot exceed Max Value</errorMessage>
</ValidationRule>
