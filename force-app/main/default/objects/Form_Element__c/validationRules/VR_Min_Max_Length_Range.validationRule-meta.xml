<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Min_Max_Length_Range</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Min_Length__c)),
  NOT(ISBLANK(Max_Length__c)),
  Min_Length__c &gt; Max_Length__c
)</errorConditionFormula>
    <errorDisplayField>Min_Length__c</errorDisplayField>
    <errorMessage>Min Length cannot exceed Max Length</errorMessage>
</ValidationRule>
