<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Field_Type_Requires_API_Name</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Type__c, &quot;Field&quot;),
  ISBLANK(Field_API_Name__c)
)</errorConditionFormula>
    <errorDisplayField>Field_API_Name__c</errorDisplayField>
    <errorMessage>Field API Name is required for Field type elements</errorMessage>
</ValidationRule>
