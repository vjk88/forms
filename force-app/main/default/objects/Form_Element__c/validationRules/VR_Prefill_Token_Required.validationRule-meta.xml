<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Prefill_Token_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISPICKVAL(Prefill_Type__c, &quot;&quot;)),
  NOT(ISPICKVAL(Prefill_Type__c, &quot;None&quot;)),
  ISBLANK(Prefill_Token__c)
)</errorConditionFormula>
    <errorDisplayField>Prefill_Token__c</errorDisplayField>
    <errorMessage>Prefill Token is required when Prefill Type is specified</errorMessage>
</ValidationRule>
