<?xml version="1.0" encoding="UTF-8" ?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>UI_Behavior__c</fullName>
    <description
  >Controls how this field renders regardless of profile permissions. None defers to the user's field-level security. Required forces the field to be mandatory. Read Only makes it display-only.</description>
    <inlineHelpText
  >None: renders based on user permissions. Required: always mandatory. Read Only: display only.</inlineHelpText>
    <label>UI Behavior</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>None</fullName>
                <default>true</default>
                <label>None</label>
            </value>
            <value>
                <fullName>Required</fullName>
                <default>false</default>
                <label>Required</label>
            </value>
            <value>
                <fullName>Read_Only</fullName>
                <default>false</default>
                <label>Read Only</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
