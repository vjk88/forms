<apex:page
    controller="FinalStudioPageController"
    showHeader="false"
    sidebar="false"
    standardStylesheets="false"
    applyHtmlTag="false"
    applyBodyTag="false"
    docType="html-5.0"
>
    <html>
        <head>
            <title>Form Studio</title>
            <meta
                name="viewport"
                content="width=device-width, initial-scale=1"
            />
            <style>
                html,
                body {
                    height: 100%;
                    margin: 0;
                    background: #fff;
                }
                #studio-root {
                    min-height: 100%;
                }
                .studio-boot {
                    height: 100vh;
                    display: grid;
                    place-items: center;
                    color: #5c5c5c;
                    font:
                        14px -apple-system,
                        'Segoe UI',
                        Roboto,
                        Helvetica,
                        Arial,
                        sans-serif;
                }
            </style>
        </head>
        <body>
            <apex:includeLightning />
            <div id="studio-boot" class="studio-boot">
                Opening Form Studio&#8230;
            </div>
            <div id="studio-root"></div>
            <script>
                (function () {
                    var params = new URLSearchParams(window.location.search);
                    var formId =
                        params.get('c__formId') || params.get('formId');
                    var exitUrl =
                        '{!JSENCODE(lightningHost)}' +
                        '/lightning/n/Final_Forms';
                    if (!formId) {
                        // the library IS the picker — same contract as the LEX tab
                        window.location.replace(exitUrl);
                        return;
                    }
                    $Lightning.use('c:finalStudioOut', function () {
                        $Lightning.createComponent(
                            'c:finalFormStudio',
                            { hostFormId: formId, exitUrl: exitUrl },
                            'studio-root',
                            function () {
                                var boot =
                                    document.getElementById('studio-boot');
                                if (boot) {
                                    boot.parentNode.removeChild(boot);
                                }
                            }
                        );
                    });
                })();
            </script>
        </body>
    </html>
</apex:page>
