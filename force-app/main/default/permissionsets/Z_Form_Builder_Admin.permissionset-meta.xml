        <editable>true</editable>
        <readable>true</readable>
        <field>Z_Form_Submission__c.Z_Primary_Record_Id__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>Z_Form_Submission__c.Z_Submission_Payload__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>Z_Form_Submission__c.Z_Submitted_Date__c</field>
    </fieldPermissions>
</PermissionSet>
